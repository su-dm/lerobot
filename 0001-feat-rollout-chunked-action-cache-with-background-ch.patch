+def _wait_for_prefetch_result(engine, timeout=5.0):
+    import time
+
+    deadline = time.monotonic() + timeout
+    while time.monotonic() < deadline:
+        if not engine._result_q.empty():
+            return
+        time.sleep(0.005)
+    raise AssertionError("timed out waiting for prefetch worker")
+
